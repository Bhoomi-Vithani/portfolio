    "scripts": {
        "about:watch:pages": "echo run lsg.components in watch mode, so you can e.g. run build:watch + npx serve dist in pages.test to develop lsg.components and pages.test at the same time.",
        "build": "run-s clean && rollup -c && node scripts/extractDocsFilePath.js && npm pack --quiet .",
        "build:copyfiles": "copyfiles -u 1 -a public/images/* public/images/**/* public/dummy-images/* public/dummy-images/**/* public/dummy-videos/* public/dummy-videos/**/* dist/public/ && copyfiles -u 1 src/components/**/*.md dist/docs",
        "build:fast": "cross-env LSG_FAST_BUILD=true npm run build",
        "build:storybook": "run-s clean:storybook && cross-env LSG_STORY=** STORYBOOK_ASSET_PATH=/styleguide/storybook storybook build -o ../lsg.storybook/dist",
        "build:storybook-copyfiles": "copyfiles -u 4 src/components/**/__test-samples__/* ../lsg.storybook/dist/__test-samples__/ && copyfiles -u 4 src/components/**/__test-report__/* ../lsg.storybook/dist/__test-report__/",
        "clean": "rimraf dist/* && rimraf ./*.tgz",
        "clean:storybook": "rimraf ../lsg.storybook/dist ../lsg.storybook/*.tgz",
        "createLsgPrefix": "node scripts/createLsgPrefix.mjs",
        "start": "cross-env LSG_STORY=** STORYBOOK_ASSET_PATH= storybook dev -p 6006",
        "start:paragraph": "cross-env LSG_STORY=Paragraph STORYBOOK_ASSET_PATH= storybook dev -p 6006 --no-open",
        "start:story": "cross-env STORYBOOK_ASSET_PATH= storybook dev -p 6006",
        "serve:components": "serve dist/test",
        "test": "nyc node scripts/test-launcher-playwright.mjs",
        "test:watch": "node --loader ts-node/esm scripts/test-launcher-playwright-watch.mts",
        "test:playwright-skip-build": "cross-env LSG_SKIP_BUILD=true node --loader ts-node/esm scripts/test-launcher-playwright-watch.mts",
        "test:build": "rollup -c rollup.test.config.mjs && copyfiles -u 1 \"public_test/**/*\" dist/test",
        "test:build-watch": "copyfiles -u 1 \"public_test/**/*\" dist/test && rollup -w --silent -c rollup.test.config.mjs",
        "test:serve": "serve dist/test",
        "test:show-report": "playwright show-report --port=9400",
        "watch:pages": "run-s clean && rollup -w -c"
    },
    "sideEffects": [
        "**/*.styles.ts",
        "./dist/**/*.styles.js",
        "./dist/*/index.js",
        "./dist/polyfills.js",
        "./dist/styles/bundle.css"
    ]
